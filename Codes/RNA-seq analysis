###### PATHWAY ANALYSIS##########
#################################

#### Extract columns from DESeq
# Filter only up-regulated genes
up_genes <- res_df[res_df$color == "up", c("Gene", "log2FoldChange", "padj")]

# Reset row names
rownames(up_genes) <- NULL

# View the new dataframe
head(up_genes)

library(pathfindR)
library(cicero)
library(dplyr)

# Load custom KEGG gene sets
mmu_kegg_genes <- readRDS("/home/mmu_kegg_genes.RDS") #change name here and path
mmu_kegg_descriptions <- readRDS("/home/mmu_kegg_descriptions.RDS") #change name here and path

# Use DE results as input
RA_input <- up_genes 
input <- as.data.frame(RA_input)
set.seed(24)
knitr::kable(head(input))

# Run pathfindR (non-human analysis with custom gene sets)
output2 <- run_pathfindR(input = input,
                         p_val_threshold = 1,
                         gene_sets = "Custom",
                         custom_genes = mmu_kegg_genes,
                         custom_descriptions = mmu_kegg_descriptions)

Resultp <- as.data.frame(output2)
write.csv(Resultp ,"/home/PathwaysUp.csv", row.names = TRUE) #change name here and path



